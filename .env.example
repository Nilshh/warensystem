# Konfiguration & Secrets — Kopiere diese Datei nach ".env" und passe sie an:
#   cp .env.example .env
# Die echte .env wird NICHT eingecheckt (siehe .gitignore).

# Standard eBay-Gebühr in % (nur Vorschlag im Formular)
EBAY_FEE_PERCENT=11.0

# eBay-API — erst ausfüllen, wenn ein Developer-Account vorhanden ist.
#
# Für den IMPORT per Link (Browse API) reichen diese beiden Werte
# (App ID + Cert ID aus dem Production-Keyset):
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Nur für die spätere vollautomatische Verkaufs-Synchronisierung nötig:
EBAY_REFRESH_TOKEN=

# Marktplatz und Umgebung.
#   EBAY_ENV: production | sandbox   (Sandbox nur zum Testen mit Sandbox-Keys)
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_ENV=production
