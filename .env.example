# Konfiguration & Secrets — Kopiere diese Datei nach ".env" und passe sie an:
#   cp .env.example .env
# Die echte .env wird NICHT eingecheckt (siehe .gitignore).

# Standard eBay-Gebühr in % (nur Vorschlag im Formular)
EBAY_FEE_PERCENT=11.0

# Verkaufte Artikel nach X Tagen automatisch archivieren (0 = deaktiviert)
ARCHIVE_AFTER_DAYS=7

# Automatische Sicherungen: Intervall in Stunden (0 = aus) und Aufbewahrung
AUTO_BACKUP_HOURS=24
KEEP_BACKUPS=10

# --- Sendungsverfolgung (DHL) ---
# Kostenloser API-Key von developer.dhl.com ("Shipment Tracking - Unified").
# Ohne Key bleibt die Sendungsverfolgung inaktiv.
# Hermes hat keine offizielle API für Privatkunden und bleibt manuell.
DHL_API_KEY=
TRACKING_INTERVAL_HOURS=12   # 12 = 2x täglich (0 = aus)
TRACKING_STUCK_DAYS=7        # ab wann eine Sendung im Dashboard gemeldet wird
TRACKING_MAX_DAYS=60         # danach nicht mehr abfragen

# Präfix der automatischen Artikelnummer (z.B. WA-00001)
ARTICLE_NO_PREFIX=WA-

# Basis-URL für QR-Codes/Etiketten (worauf der QR-Code zeigt)
BASE_URL=http://wa.home

# Absenderdaten für Lieferschein/Packzettel (erscheinen als Absender oben)
# Mehrzeilige Adresse mit \n trennen, z.B. "Musterstr. 1\n12345 Musterstadt"
SELLER_NAME=
SELLER_ADDRESS=
SELLER_EMAIL=
SELLER_PHONE=

# eBay-API — erst ausfüllen, wenn ein Developer-Account vorhanden ist.
#
# Für den IMPORT per Link (Browse API) reichen diese beiden Werte
# (App ID + Cert ID aus dem Production-Keyset):
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Nur für die spätere vollautomatische Verkaufs-Synchronisierung nötig:
EBAY_REFRESH_TOKEN=

# Marktplatz und Umgebung.
#   EBAY_ENV: production | sandbox   (Sandbox nur zum Testen mit Sandbox-Keys)
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_ENV=production
